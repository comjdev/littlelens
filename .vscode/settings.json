{
	// Set EJS Beautify as the default formatter for .ejs files
	"[ejs]": {
		"editor.defaultFormatter": "j69.ejs-beautify"
	},

	// Optional but recommended: Disable Prettier specifically for EJS files
	// This ensures Prettier doesn't even try to format them.
	"prettier.disableLanguages": ["ejs"],

	// Use AWS profile 'gill' for this project (Lambda, S3, etc.)
	"terminal.integrated.env.osx": {
		"AWS_PROFILE": "gill"
	},
	"terminal.integrated.env.linux": {
		"AWS_PROFILE": "gill"
	},
	"terminal.integrated.env.windows": {
		"AWS_PROFILE": "gill"
	}
}
