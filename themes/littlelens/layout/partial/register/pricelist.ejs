<h2 class="!mt-12 uppercase tracking-wide text-gray-900">Little Lens Photo Day Collections</h2>

<p class="mt-3 mb-8 text-gray-600">
  Simple, beautiful options designed to make choosing easy.
</p>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
  <% site.data.prices.collections.forEach(function(card) { %>
  <div
    class="relative flex flex-col p-6 md:p-8 rounded-xl border shadow-sm transition-shadow hover:shadow-md <%= card.popular ? 'md:scale-[1.02] bg-little-lens-green-50/60 border-little-lens-green-200' : 'bg-white border-gray-100' %>"
  >
    <% if (card.popular) { %>
    <span
      class="absolute top-4 right-4 px-3 py-1 text-xs font-medium rounded-full bg-little-lens-green-700 text-white"
    >
      Most Popular
    </span>
    <% } %>
    <div class="mb-4">
      <h3 class="text-sm font-medium uppercase tracking-wide text-gray-900">
        <%- card.name %> – $<%= card.price %>
      </h3>
    </div>
    <ul class="space-y-3 mb-6 text-sm text-gray-700 list-none pl-0">
      <% card.features.forEach(function(feature) { %>
      <li class="flex items-start gap-2.5">
        <svg
          class="w-4 h-4 mt-0.5 shrink-0 text-little-lens-green-600"
          aria-hidden="true"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"
          />
        </svg>
        <span><%= feature %></span>
      </li>
      <% }); %>
    </ul>
    <p class="mt-auto text-sm text-gray-600 italic">
      <%- card.description %>
    </p>
  </div>
  <% }); %>

  <div
    class="relative flex flex-col p-6 md:p-8 rounded-xl border shadow-sm transition-shadow hover:shadow-md bg-white border-gray-100 md:col-span-2"
  >
    <div class="mb-4">
      <h3 class="text-sm font-medium uppercase tracking-wide text-gray-900">
        Digital Downloads
      </h3>
    </div>
    <ul class="space-y-3 mb-6 text-sm text-gray-700 list-none pl-0">
      <li class="flex items-start gap-2.5">
        <svg
          class="w-4 h-4 mt-0.5 shrink-0 text-little-lens-green-600"
          aria-hidden="true"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"
          />
        </svg>
        <span>1 digital image – $25</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg
          class="w-4 h-4 mt-0.5 shrink-0 text-little-lens-green-600"
          aria-hidden="true"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"
          />
        </svg>
        <span>5 digital images – $85</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg
          class="w-4 h-4 mt-0.5 shrink-0 text-little-lens-green-600"
          aria-hidden="true"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"
          />
        </svg>
        <span>10 digital images – $135</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg
          class="w-4 h-4 mt-0.5 shrink-0 text-little-lens-green-600"
          aria-hidden="true"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"
          />
        </svg>
        <span>All digital images – $165</span>
      </li>
    </ul>
  </div>
</div>
