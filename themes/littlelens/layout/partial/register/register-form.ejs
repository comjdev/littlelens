        id="firstname"
        name="parent-firstname"
        class="block p-3 w-full text-sm text-gray-900 bg-little-lens-light-400 rounded-lg border border-gray-300 shadow-sm focus:ring-little-lens-green-500 focus:border-little-lens-green-500"
        placeholder="Your First Name"
        required
      />
    </div>
    <div>
      <label
        for="lastname"
        class="block mb-2 text-sm font-medium text-gray-900"
      >
        Last Name</label
      >
      <input
        type="text"
        id="lastname"
        name="parent-lastname"
        class="block p-3 w-full text-sm text-gray-900 bg-little-lens-light-400 rounded-lg border border-gray-300 shadow-sm focus:ring-little-lens-green-500 focus:border-little-lens-green-500"
        placeholder="Your Last Name"
        required
      />
    </div>
  </div>

  <!-- Email and Mobile Number -->

  <div class="grid md:grid-cols-2 md:gap-6">
    <div>
      <label for="email" class="block mb-2 text-sm font-medium text-gray-900">
        Email Address
      </label>
