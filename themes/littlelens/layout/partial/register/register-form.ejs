<div id="single-pricelist-container">
  <%- partial('partial/register/pricelist') %>
</div>
<div id="family-pricelist-container" class="hidden">
  <%- partial('partial/register/family-pricelist') %>
</div>

<script>
  const BOOKINGS_API =
    "https://script.google.com/macros/s/AKfycbzluzXsnbThx3_nksrCnw8illiZuZXE9VwGAHTEFIM54qNbHpQnwmSaviq8xF81_LvU/exec";

  let bookingsData = [];

  const fetchBookings = async () => {
    try {
      const response = await fetch(BOOKINGS_API);
      if (!response.ok) throw new Error("Network response was not ok");

      bookingsData = await response.json();
      processBookingsData();
      populateCentreDropdown();

      // Pre-select centre from URL if present
      const centreFromUrl = new URLSearchParams(window.location.search).get(
        "c",
      );

      if (centreFromUrl) {
        const centreSelect = document.getElementById("centre-name");

        // Wait until the dropdown is populated
        const isValidCentre = Array.from(centreSelect.options).some(
          (option) => option.value === centreFromUrl,
        );

        if (isValidCentre) {
          // Show selected centre in text
          const centreFromUrlText = document.getElementById("centre-from-url");
          if (centreFromUrlText) {
            centreFromUrlText.textContent = `for ${centreFromUrl}`;
          }

          // Keep only the matching centre option
          centreSelect.innerHTML = ""; // clear all options
          const option = document.createElement("option");
          option.value = centreFromUrl;
          option.textContent = centreFromUrl;
          option.selected = true;
          centreSelect.appendChild(option);

          // Populate room dropdown for this centre
          populateRoomDropdown(centreFromUrl);
          populateSiblingRoomDropdowns(centreFromUrl);

          // Populate date dropdown for this centre
          populateDateDropdown(centreFromUrl);
        } else {
          console.warn(
            `Centre "${centreFromUrl}" not found in available options.`,
          );
        }
      }
    } catch (error) {
      console.error("Error fetching bookings:", error);
    }
  };

  const isFutureDate = (dateStr, now) => {
    const [day, month, year] = dateStr.split("/");
    const date = new Date(`${year}-${month}-${day}`);

    const isToday = date.toDateString() === now.toDateString();
    const isAfterCutoff = now.getHours() > 10;

    return date > now || (isToday && !isAfterCutoff);
  };

  const processBookingsData = () => {
    const now = new Date();

    bookingsData.forEach((centre) => {
      centre.Dates = centre.Dates.filter((dateObj) =>
        isFutureDate(dateObj.Date, now),
      );
    });

    bookingsData = bookingsData
      .filter((centre) => centre.Dates.length > 0)
      .sort((a, b) => a.Center.localeCompare(b.Center));

    bookingsData.forEach((centre) => {
      centre.Dates.sort((a, b) => {
        const [dA, mA, yA] = a.Date.split("/");
        const [dB, mB, yB] = b.Date.split("/");
        return new Date(`${yA}-${mA}-${dA}`) - new Date(`${yB}-${mB}-${dB}`);
      });
    });
  };

  const populateCentreDropdown = () => {
    const select = document.getElementById("centre-name");
    select.innerHTML = "<option disabled selected>Select your centre</option>";

    bookingsData.forEach((centre) => {
      const option = document.createElement("option");
      option.value = centre.Center;
      option.textContent = centre.Center;
      select.appendChild(option);
    });
  };

  const populateRoomDropdown = (selectedCentre) => {
    const select = document.getElementById("room");
    select.innerHTML =
      "<option disabled selected>Select your child's Group/Room</option>";
    console.log("populateRoomDropdown", selectedCentre);
    console.log("bookingsData", bookingsData);

    const centre = bookingsData.find((c) => c.Center === selectedCentre);
    if (!centre) return;

    centre.Rooms.forEach((room) => {
      const option = document.createElement("option");
      option.value = room;
      option.textContent = room;
      select.appendChild(option);
    });
  };

  const populateSiblingRoomDropdowns = (selectedCentre) => {
    const siblingRoomSelect = document.getElementById("sibling-room");
    const centre = bookingsData.find((c) => c.Center === selectedCentre);
    if (!centre) return;

    const applyRooms = (selectEl, placeholder) => {
      if (!selectEl) return;
      selectEl.innerHTML = `<option disabled selected>${placeholder}</option>`;
      centre.Rooms.forEach((room) => {
        const option = document.createElement("option");
        option.value = room;
        option.textContent = room;
        selectEl.appendChild(option);
      });
    };

    applyRooms(siblingRoomSelect, "Sibling's Group/Room");
    // Apply to all dynamic sibling blocks
    document
      .querySelectorAll("#siblings-container .sibling-room")
      .forEach((selectEl) => {
        applyRooms(selectEl, "Sibling's Group/Room");
      });
  };

  const populateDateDropdown = (selectedCentre) => {
    const select = document.getElementById("photo-day");
    select.innerHTML = "<option disabled selected>Select a date</option>";

    const centre = bookingsData.find((c) => c.Center === selectedCentre);
    if (!centre) return;

    centre.Dates.forEach(({ Date: dateStr, Registrations }) => {
      const [day, month, year] = dateStr.split("/");
      const dateObj = new Date(`${year}-${month}-${day}`);
      const dayOfWeek = dateObj.toLocaleDateString("en-AU", {
        weekday: "long",
      });

      const option = document.createElement("option");
      option.value = dateStr;
      option.textContent = `${dayOfWeek}, ${dateStr}`;

      if (Registrations >= 25) {
        option.textContent +=
          " (fully booked – only select if it's your child's only day at the centre)";
      } else if (Registrations >= 20) {
        option.textContent += " (almost full)";
      }

      select.appendChild(option);
    });
  };

  const syncSiblingDateWithPhotoDay = () => {
    const photoDaySelect = document.getElementById("photo-day");
    const sameDayText = document.getElementById("same-day-text");
    if (!photoDaySelect) return;
    const selectedValue = photoDaySelect.value || "";
    // Set on the first sibling date input if it exists
    const firstSiblingDate = document.getElementById("sibling-date");
    if (firstSiblingDate) firstSiblingDate.value = selectedValue;
    // Apply to all dynamic sibling blocks
    document
      .querySelectorAll("#siblings-container .sibling-date")
      .forEach((input) => {
        input.value = selectedValue;
      });

    if (sameDayText) {
      const selectedText =
        photoDaySelect.options[photoDaySelect.selectedIndex]?.textContent ||
        "same day";
      sameDayText.innerHTML = `<strong>${selectedText}</strong>`;
    }
  };

  document.getElementById("centre-name").addEventListener("change", (e) => {
    populateDateDropdown(e.target.value);
    populateRoomDropdown(e.target.value);
    populateSiblingRoomDropdowns(e.target.value);
  });

  document.getElementById("photo-day").addEventListener("change", () => {
    syncSiblingDateWithPhotoDay();
  });

  fetchBookings();
</script>

<script>
  const CHECKOUT_API =
    "https://8xiczk0ua0.execute-api.us-east-1.amazonaws.com/default/checkout";

  const DEPOSIT_PER_CHILD = 25;
  const form = document.getElementById("registerForm");
  const childFirstNameInput = document.getElementById("child-firstname");
  const registerName = document.getElementById("register-name");
  const thankYouName = document.getElementById("thank-you-child-name");
  const childNameSpan = document.getElementById("child-name");
  const depositAmountSpan = document.getElementById("deposit-amount");
  const siblingSessionNote = document.getElementById("sibling-session-note");
  const singlePricelistContainer = document.getElementById("single-pricelist-container");
  const familyPricelistContainer = document.getElementById("family-pricelist-container");
  const siblingCheckbox = document.getElementById("sibling");
  const siblingNameContainer = document.getElementById(
    "sibling-name-container",
  );
  const siblingFirstNameInput = document.getElementById("sibling-firstname");
  const siblingLastNameInput = document.getElementById("sibling-lastname");
  const siblingLasRoomInput = document.getElementById("sibling-room");
  const addSiblingBtn = document.getElementById("add-sibling");
  const siblingsContainer = document.getElementById("siblings-container");

  const showLoadingState = (message = "Creating checkout...") => {
    document.getElementById("formLoading").classList.remove("hidden");
    document.getElementById("formSuccess").classList.add("hidden");
    document.getElementById("formError").classList.add("hidden");

    const loadingSpan = document.querySelector("#formLoading .font-medium");
    if (loadingSpan) loadingSpan.textContent = message;

    // Disable submit button to prevent multiple submissions
    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Processing...";
    }
  };

  const handleFormSuccess = () => {
    document.getElementById("formLoading").classList.add("hidden");
    document.getElementById("formSuccess").classList.remove("hidden");
  };

  const handleFormError = () => {
    document.getElementById("formLoading").classList.add("hidden");
    document.getElementById("formError").classList.remove("hidden");

    // Re-enable submit button on error
    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.innerHTML =
        'Register <span id="register-name">your child</span>';
    }
  };

  const handleFormSubmit = async (e) => {
    e.preventDefault();
    showLoadingState();

    const formData = new FormData(form);
    const rawData = Object.fromEntries(formData.entries());

    // Collect siblings into an array
    const siblings = [];
    const siblingBlocks = document.querySelectorAll(
      "#siblings-container .sibling-block",
    );

    siblingBlocks.forEach((block) => {
      const firstname = block
        .querySelector('input[name="sibling-firstname"]')
        ?.value?.trim();
      const lastname = block
        .querySelector('input[name="sibling-lastname"]')
        ?.value?.trim();
      const room = block
        .querySelector('select[name="sibling-room"]')
        ?.value?.trim();

      if (firstname) {
        siblings.push({
          firstname: firstname,
          lastname: lastname || "",
          room: room || "",
        });
      }
    });

    const childFirst = rawData["child-firstname"] || "";
    const childLast = rawData["child-lastname"] || "";
    const parentFirst = rawData["parent-firstname"] || "";
    const parentLast = rawData["parent-lastname"] || "";

    const checkoutPayload = {
      childName: `${childFirst} ${childLast}`.trim(),
      parentName: `${parentFirst} ${parentLast}`.trim(),
      parentEmail: rawData["parent-email"] || "",
      centreName: rawData["centre-name"] || "",
      siblings,
      childFirstname: childFirst,
      childLastname: childLast,
      parentFirstname: parentFirst,
      parentLastname: parentLast,
      photoDay: rawData["photo-day"] || "",
      room: rawData["room"] || "",
      parentPhone: rawData["parent-phone"] || "",
    };

    try {
      const response = await fetch(CHECKOUT_API, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(checkoutPayload),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.message || "Checkout failed");
      }

      if (data.url) {
        showLoadingState("Redirecting to checkout...");
        window.location.href = data.url;
      } else {
        throw new Error("No checkout URL received");
      }
    } catch (error) {
      console.error("Submission error:", error);
      handleFormError();
    }
  };

  const updateChildrenNames = () => {
    const childName = childFirstNameInput.value || "your child";

    // Build children list for button and success message
    let childrenList = childName;
    const siblingBlocks = document.querySelectorAll(
      "#siblings-container .sibling-block",
    );
    const siblingNames = [];

    siblingBlocks.forEach((block) => {
      const siblingFirst = block.querySelector(
        'input[name="sibling-firstname"]',
      );
      if (siblingFirst && siblingFirst.value.trim()) {
        siblingNames.push(siblingFirst.value.trim());
      }
    });

    if (siblingNames.length > 0) {
      childrenList += ` & ${siblingNames.join(" & ")}`;
    }

    // Child count: main (1) + siblings with first name
    const childCount = 1 + siblingNames.length;
    const totalDeposit = DEPOSIT_PER_CHILD * childCount;

    if (registerName) registerName.textContent = childrenList;
    if (thankYouName) thankYouName.textContent = childrenList;
    if (childNameSpan) childNameSpan.textContent = childrenList;
    if (depositAmountSpan) depositAmountSpan.textContent = `$${totalDeposit}`;
    if (siblingSessionNote) siblingSessionNote.classList.toggle("hidden", siblingNames.length === 0);
    const hasSiblings = siblingNames.length > 0;
    if (singlePricelistContainer) singlePricelistContainer.classList.toggle("hidden", hasSiblings);
    if (familyPricelistContainer) familyPricelistContainer.classList.toggle("hidden", !hasSiblings);

    // Update placeholders for dynamic blocks
    siblingBlocks.forEach((block, index) => {
      const first = block.querySelector('input[name="sibling-firstname"]');
      const last = block.querySelector('input[name="sibling-lastname"]');
      if (first) first.placeholder = `First name of ${childName}'s sibling`;
      if (last) last.placeholder = `Last name of ${childName}'s sibling`;
    });
  };

  const handleNameInput = () => {
    updateChildrenNames();
  };

  const handleSiblingToggle = () => {
    const show = siblingCheckbox.checked;
    siblingNameContainer.classList.toggle("hidden", !show);
    siblingFirstNameInput.required = show;
    siblingLastNameInput.required = show;
    siblingLasRoomInput.required = show;
    if (addSiblingBtn) {
      addSiblingBtn.classList.toggle("hidden", !show);
    }
    if (!show) {
      // Remove all dynamic siblings
      document
        .querySelectorAll("#siblings-container .sibling-block")
        .forEach((block, idx) => {
          if (idx > 0) block.remove();
        });
      // Hide remove button on the initial block
      const firstRemove = document.querySelector(
        "#siblings-container .sibling-block .remove-sibling",
      );
      if (firstRemove) firstRemove.classList.add("hidden");
      // Reset inputs in the first block
      const firstBlock = document.querySelector(
        "#siblings-container .sibling-block",
      );
      if (firstBlock) {
        firstBlock.querySelectorAll("input").forEach((i) => {
          i.value = "";
          i.required = false;
        });
        const room = firstBlock.querySelector(".sibling-room");
        if (room) room.selectedIndex = 0;
      }
      if (addSiblingBtn) addSiblingBtn.classList.add("hidden");
    }
    updateChildrenNames();
  };

  // Event listeners
  childFirstNameInput.addEventListener("input", handleNameInput);
  siblingFirstNameInput.addEventListener("input", updateChildrenNames);
  siblingCheckbox.addEventListener("change", handleSiblingToggle);
  form.addEventListener("submit", handleFormSubmit);

  const addSiblingFromTemplate = () => {
    const template = document.getElementById("sibling-template");
    if (!template || !siblingsContainer) return;
    const clone = template.content.cloneNode(true);
    siblingsContainer.appendChild(clone);

    // Add event listeners to new sibling inputs
    const newBlock = siblingsContainer.lastElementChild;
    const siblingFirstInput = newBlock.querySelector(
      'input[name="sibling-firstname"]',
    );
    if (siblingFirstInput) {
      siblingFirstInput.addEventListener("input", updateChildrenNames);
    }

    // Populate rooms for the new block
    const centreSelect = document.getElementById("centre-name");
    if (centreSelect && centreSelect.value) {
      populateSiblingRoomDropdowns(centreSelect.value);
    }
    // Sync date immediately
    syncSiblingDateWithPhotoDay();
  };

  if (addSiblingBtn) {
    addSiblingBtn.addEventListener("click", addSiblingFromTemplate);
  }

  // Delegate remove button clicks
  if (siblingsContainer) {
    siblingsContainer.addEventListener("click", (e) => {
      const target = e.target;
      if (
        target &&
        target.classList &&
        target.classList.contains("remove-sibling")
      ) {
        const block = target.closest(".sibling-block");
        if (!block) return;
        const allBlocks = siblingsContainer.querySelectorAll(".sibling-block");
        if (allBlocks.length > 1) {
          block.remove();
        } else {
          // On the first block, just clear inputs
          block.querySelectorAll("input").forEach((i) => {
            i.value = "";
          });
          const room = block.querySelector(".sibling-room");
          if (room) room.selectedIndex = 0;
        }
        updateChildrenNames();
      }
    });
  }
</script>
