      </p>
    </div>
  </div>

  <hr class="h-px my-8 bg-gray-200 border-0" />

  <!-- Childcare Center  -->
  <h2>Childcare Centre / Kindergarten</h2>
  <div>
    <label
      for="centre-name"
      class="block mb-2 text-sm font-medium text-gray-900"
