<form id="registerForm" class="space-y-8">
  <div class="text-3xl font-bold text-gray-900 mb-1">
    Register for Photo Day
  </div>
  <div id="centre-from-url" class="text-md text-gray-500">
    for outdoor and portrait photos
  </div>

  <div class="">
    <p class="block m-0! p-0 text-gray-600">
      To ensure we can dedicate time and care to every child, a $25 booking
      deposit per child is required when registering.
    </p>
    <p class="block m-0! p-0 text-gray-600">
      This deposit is <strong>fully credited towards your photo order</strong>, so you won’t pay
      anything extra when purchasing your photo packages.
    </p>
    <p class="block m-0! p-0 text-gray-600">
      If no photo package is ordered, the deposit is retained as a booking
      commitment.
    </p>
    <p class="block m-0! p-0 text-gray-600">
      This approach allows us to plan photo day efficiently and give every child
      the attention they deserve.
    </p>
  </div>

  <!-- Child'd name  -->
  <h2>Child's name</h2>
  <div class="grid md:grid-cols-2 md:gap-6">
    <div>
      <label
        for="child-firstname"
        class="block mb-2 text-sm font-medium text-gray-900"
      >
        First Name
      </label>
      <input
        type="text"
        id="child-firstname"
        name="child-firstname"
        class="block p-3 w-full text-sm text-gray-900 bg-little-lens-light-400 rounded-lg border border-gray-300 shadow-sm focus:ring-little-lens-green-500 focus:border-little-lens-green-500"
        placeholder="Child's First Name"
        required
      />
    </div>
    <div>
      <label
        for="child-lastname"
        class="block mb-2 text-sm font-medium text-gray-900"
      >
        Last Name</label
      >
      <input
        type="text"
        id="child-lastname"
        name="child-lastname"
        class="block p-3 w-full text-sm text-gray-900 bg-little-lens-light-400 rounded-lg border border-gray-300 shadow-sm focus:ring-little-lens-green-500 focus:border-little-lens-green-500"
        placeholder="Child's Last Name"
        required
      />
    </div>
  </div>

  <!-- Parent's Name  -->
